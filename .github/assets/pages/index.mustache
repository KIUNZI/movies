<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Build Reports</title>
    <link rel="stylesheet" href="./style.css">
  </head>
  <body>
    <header class="page-header">
      <h1>Build Reports</h1>
      <p class="subtitle">CI artefacts generated from <strong>main</strong></p>
    </header>

    <main class="container">
      <section>
        <h2>Test Reports</h2>
        <ul class="card-grid">
{{#testReports}}
          <li class="card">
            <a href="./test-report/{{module}}/">
              <span class="card-title">{{module}}</span>
              <span class="card-meta">{{description}}</span>
            </a>
          </li>
{{/testReports}}
        </ul>
      </section>

      <section>
        <h2>Public API Documentation</h2>
        <ul class="card-grid">
{{#javadocs}}
          <li class="card">
            <a href="./javadocs/{{module}}/">
              <span class="card-title">{{module}}</span>
              <span class="card-meta">{{description}}</span>
            </a>
          </li>
{{/javadocs}}
        </ul>
      </section>
    </main>

    <footer>
      <p>Generated by GitHub Actions · <time id="ts"></time></p>
    </footer>

    <script>
      document.getElementById("ts").textContent =
        new Date().toISOString().replace("T", " ").replace("Z", " UTC");
    </script>
  </body>
</html>

